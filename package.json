{
  "name": "pvz-manager",
  "version": "1.0.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start --offline",
    "start:online": "expo start",
    "start:clean": "expo start -c --offline",
    "android": "expo run:android",
    "android:install": "cd android && gradlew.bat installRelease",
    "ios": "expo run:ios",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit",
    "build:preview:android": "eas build --profile preview --platform android",
    "build:preview:ios": "eas build --profile preview --platform ios",
    "build:production": "eas build --profile production --platform all",
    "eas:check": "node scripts/ensure-eas-env.mjs",
    "fcm:check": "node scripts/ensure-fcm-setup.mjs",
    "eas:secrets:push": "node scripts/push-eas-secrets.mjs",
    "lint": "eslint \"src/**/*.{ts,tsx}\" App.tsx index.ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "verify:api": "node scripts/verify-api-https.mjs",
    "format": "prettier --write \"src/**/*.{ts,tsx}\" App.tsx index.ts",
    "assets:generate": "node scripts/generate-brand-assets.mjs",
    "apk:link": "node scripts/apk-direct-link.mjs",
    "site:sync": "node scripts/sync-legal-site.mjs",
    "deploy:api": "node scripts/deploy-api.mjs",
    "deploy:api:py": "python scripts/deploy-api-paramiko.py",
    "check:dns": "node scripts/check-pvzpersonal-dns.mjs",
    "check:email": "node scripts/check-notisend-delivery.mjs"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@noble/ciphers": "^2.2.0",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/datetimepicker": "8.4.4",
    "@react-native-community/netinfo": "11.4.1",
    "@react-navigation/bottom-tabs": "^7.16.2",
    "@react-navigation/native": "^7.2.5",
    "@react-navigation/native-stack": "^7.16.0",
    "@tanstack/react-query": "^5.101.0",
    "expo": "~54.0.33",
    "expo-build-properties": "~1.0.10",
    "expo-constants": "~18.0.13",
    "expo-crypto": "~15.0.8",
    "expo-device": "~8.0.10",
    "expo-file-system": "~19.0.23",
    "expo-font": "~14.0.12",
    "expo-linear-gradient": "~15.0.8",
    "expo-local-authentication": "~17.0.8",
    "expo-localization": "~17.0.9",
    "expo-location": "~19.0.8",
    "expo-modules-core": "~3.0.30",
    "expo-notifications": "~0.32.17",
    "expo-secure-store": "~15.0.8",
    "expo-sharing": "~14.0.8",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-task-manager": "~14.0.9",
    "i18next": "^26.3.1",
    "lucide-react-native": "^1.16.0",
    "react": "19.1.0",
    "react-i18next": "^17.0.8",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-url-polyfill": "^3.0.0"
  },
  "devDependencies": {
    "@types/jest": "^29.5.14",
    "@types/react": "~19.1.0",
    "@typescript-eslint/eslint-plugin": "^8.46.2",
    "@typescript-eslint/parser": "^8.46.2",
    "babel-plugin-transform-remove-console": "^6.9.4",
    "babel-preset-expo": "~54.0.10",
    "eslint": "^9.39.1",
    "eslint-config-prettier": "^10.1.8",
    "jest": "^29.7.0",
    "jest-expo": "~54.0.13",
    "pg": "^8.16.3",
    "prettier": "^3.6.2",
    "sharp": "^0.35.0",
    "ssh2": "^1.17.0",
    "typescript": "~5.9.2"
  },
  "private": true
}
