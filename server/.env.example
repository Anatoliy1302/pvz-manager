# Legacy Mobile Auth API (скрипты sync-smsaero-env-to-vps)
SMSAERO_CLIENT_ID=
SMSAERO_SECRET=
SMSAERO_EMAIL=
SMSAERO_API_KEY=
SMS_AERO_API_KEY=
# Алиасы (достаточно одной пары login/secret):
SMS_AERO_LOGIN=
SMS_AERO_SECRET=
SMSAERO_LOGIN=
SMSAERO_SECRET=
SMSAERO_GATE_LOGIN=
SMSAERO_GATE_API_KEY=

# Подпись и шаблон SMS (подпись должна быть одобрена в кабинете)
SMS_AERO_SIGN=PVZPersonal
SMSAERO_SIGN=PVZPersonal
SMS_AERO_MESSAGE_TEMPLATE=Ваш код для входа в PVZPersonal - {code}
SMSAERO_MESSAGE_TEMPLATE=Ваш код для входа в PVZPersonal - {code}

# Тестовый режим в кабинете SMS Aero — код 1234
SMSAERO_TEST_MODE=1
SMSAERO_TEST_CODE=
SMS_OTP_LENGTH=4

# --- API / PostgreSQL ---
PUBLIC_API_URL=https://api.pvzpersonal.ru
DATABASE_URL=postgresql://user:password@localhost:5432/pvz
JWT_SECRET=change-me-in-production
PORT=3000
NODE_ENV=production

# CORS (через запятую; мобильные клиенты без Origin — разрешены)
CORS_ORIGINS=https://pvzpersonal.ru,https://www.pvzpersonal.ru,https://api.pvzpersonal.ru

# --- NotiSend (email OTP владельцев) ---
NOTISEND_API_KEY=
# Альтернатива API-ключу (legacy SMTP):
NOTISEND_SMTP_PASSWORD=
NOTISEND_FROM_EMAIL=noreply@pvzpersonal.ru
NOTISEND_FROM_NAME=PVZ Personal
SUPPORT_EMAIL_TO=support@pvzpersonal.ru
EMAIL_TEST_MODE=0
NOTISEND_TEST_MODE=0

# Dev-only: лог OTP в консоль (не включать в production)
DEV_SMS_LOG_OTP=0

# --- Подписка (cron на VPS) ---
SUBSCRIPTION_CRON_SECRET=
# Webhook в кабинете ЮKassa: https://api.pvzpersonal.ru/api/subscription/webhook
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
YOOKASSA_RETURN_URL=pvzpersonal://payment/success
YOOKASSA_TEST_MODE=true
YOOKASSA_AUTOPAY_ENABLED=true
