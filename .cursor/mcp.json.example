{
  "mcpServers": {
    "supabase": {
      "command": "python",
      "args": [
        "-m",
        "supabase_mcp_server",
        "--project-ref",
        "YOUR_PROJECT_REF",
        "--read-only"
      ],
      "env": {
        "SUPABASE_ACCESS_TOKEN": "sbp_YOUR_PERSONAL_ACCESS_TOKEN"
      }
    }
  }
}
