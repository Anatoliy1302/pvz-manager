# Expo / client app
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...

# Optional — для локального `expo start` (dev client пересобирать после смены env)
EXPO_PUBLIC_USE_SUPABASE_PHONE_OTP=true
EXPO_PUBLIC_USE_SUPABASE_EMAIL_OTP=true
EXPO_PUBLIC_DEMO_MODE=false
EXPO_PUBLIC_APP_ENV=development

# YooKassa — Supabase Edge Function secrets only (NOT EXPO_PUBLIC_*)
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
YOOKASSA_RETURN_URL=pvzpersonal://payment/success
YOOKASSA_TEST_MODE=true
YOOKASSA_AUTOPAY_ENABLED=true
SUBSCRIPTION_CRON_SECRET=

# Supabase CLI / setup scripts (optional; alternative to .cursor/mcp.json)
# SUPABASE_ACCESS_TOKEN=sbp_...
