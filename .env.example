# Expo / client app — собственный API (обязательно для Metro)
EXPO_PUBLIC_API_URL=http://79.137.192.194:3000
# Production EAS build: https://api.pvzpersonal.ru (см. eas.json)

# Деплой API на VPS (локально: npm run deploy:api)
DEPLOY_SSH_HOST=79.137.192.194
DEPLOY_SSH_USER=root
DEPLOY_SSH_PASSWORD=...   # или DEPLOY_SSH_KEY=~/.ssh/id_rsa
DEPLOY_PATH=/opt/pvz

# GitHub Actions secrets (Settings → Secrets → Actions):
# DEPLOY_SSH_HOST, DEPLOY_SSH_USER, DEPLOY_SSH_KEY (private key, без passphrase)

# Legacy (больше не используется клиентом)
# EXPO_PUBLIC_SUPABASE_URL=
# EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Optional — для локального `expo start` (dev client пересобирать после смены env)
EXPO_PUBLIC_USE_SUPABASE_PHONE_OTP=true
# Owner: регистрация всегда по email-коду; вход — по паролю (или по коду, если true)
EXPO_PUBLIC_USE_SUPABASE_EMAIL_OTP=false
EXPO_PUBLIC_DEMO_MODE=false
EXPO_PUBLIC_APP_ENV=development

# YooKassa — Supabase Edge Function secrets only (NOT EXPO_PUBLIC_*)
# Для VPS API задайте те же переменные в server/.env (см. server/.env.example)
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=
YOOKASSA_RETURN_URL=pvzpersonal://payment/success
YOOKASSA_TEST_MODE=true
YOOKASSA_AUTOPAY_ENABLED=true
SUBSCRIPTION_CRON_SECRET=

# Supabase CLI / setup scripts (optional; alternative to .cursor/mcp.json)
# SUPABASE_ACCESS_TOKEN=sbp_...  # Dashboard → Account → Access Tokens (для enable-auth-phone.mjs)
# SUPABASE_DB_PASSWORD=...       # Database password (для MCP supabase-mcp-server и setup-скриптов)
# MERLIN_API_KEY=...             # https://merlin.build/dashboard/settings (для Merlin MCP)
