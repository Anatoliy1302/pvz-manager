# Expo / client app — собственный API (обязательно для Metro)
EXPO_PUBLIC_API_URL=https://api.pvzpersonal.ru

# Деплой API на VPS (локально: npm run deploy:api)
DEPLOY_SSH_HOST=
DEPLOY_SSH_USER=root
# DEPLOY_SSH_PASSWORD=...   # или DEPLOY_SSH_KEY=~/.ssh/id_rsa
DEPLOY_PATH=/opt/pvz

# GitHub Actions secrets (Settings → Secrets → Actions):
# DEPLOY_SSH_HOST, DEPLOY_SSH_USER, DEPLOY_SSH_KEY (private key, без passphrase)

# Feature flags (dev client пересобирать после смены)
EXPO_PUBLIC_USE_SMS_OTP=true
# Owner: регистрация по email-коду; вход — по паролю (или по коду, если true)
EXPO_PUBLIC_USE_EMAIL_OTP=false
EXPO_PUBLIC_DEMO_MODE=false
EXPO_PUBLIC_APP_ENV=development

# YooKassa / подписка — только в server/.env на VPS (см. server/.env.example)
# YOOKASSA_SHOP_ID=
# YOOKASSA_SECRET_KEY=
# YOOKASSA_RETURN_URL=pvzpersonal://payment/success
# YOOKASSA_TEST_MODE=true
# YOOKASSA_AUTOPAY_ENABLED=true
# SUBSCRIPTION_CRON_SECRET=

# SMS Aero — для скриптов синхронизации env на VPS (см. server/.env.example)
SMSAERO_EMAIL=
SMSAERO_API_KEY=
SMSAERO_LOGIN=
SMSAERO_SECRET=
SMSAERO_SIGN=PVZPersonal
SMS_AERO_SIGN=PVZPersonal
SMSAERO_TEST_MODE=0
SMS_AERO_MESSAGE_TEMPLATE=Ваш код для входа в PVZPersonal - {code}

# NotiSend — только server/.env; здесь для скриптов диагностики
NOTISEND_TEST_MODE=0

# Merlin MCP (optional)
# MERLIN_API_KEY=...
